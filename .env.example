# Copy to .env.local and fill in your Mesh key (rsk_...). Never commit real keys.

# --- Local dev (Vite) ---
# The Vite proxy reads this key and injects it; the mic also unlocks when it's set.
VITE_MESH_API_KEY=rsk_your_key_here
VITE_MESH_BASE_URL=https://api.meshapi.ai/v1
VITE_MESH_CHAT_MODEL=auto
VITE_MESH_STT_MODEL=sarvam/saaras:v3
VITE_MESH_TTS_MODEL=sarvam/bulbul:v3
VITE_MESH_TTS_VOICE=anushka

# --- Production deploy (e.g. Vercel) ---
# Set these in the host's env, NOT here. The key stays server-side (no VITE_ prefix)
# and is used by the /api/mesh serverless function:
#   MESH_API_KEY=rsk_your_key_here
#   MESH_BASE_URL=https://api.meshapi.ai/v1
# Then expose only a public flag so the client enables the mic without the key:
#   VITE_MESH_ENABLED=1
